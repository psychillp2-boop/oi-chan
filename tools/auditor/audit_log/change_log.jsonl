import json
from datetime import datetime

LOG_FILE = "tools/auditor/audit_log/change_log.jsonl"

def log_move(src, dst, reason="MOVE_PLAN"):

    record = {
        "time": str(datetime.now()),
        "src": src,
        "dst": dst,
        "reason": reason
    }

    with open(LOG_FILE, "a") as f:
        f.write(json.dumps(record) + "\n")